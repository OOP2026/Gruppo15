        </constraints>
        <properties>
          <text value="Tipo prestazione"/>
        </properties>
      </component>
      <vspacer id="9e1b6">
        <constraints>
          <grid row="12" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
      </vspacer>
      <component id="6fbad" class="javax.swing.JComboBox" binding="prestazioneComboBox">
