<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="gui.PrestazioneGUI">
  <grid id="27dc6" binding="creaPrestazionePanel" layout-manager="GridLayoutManager" row-count="13" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="500" height="437"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="b9854" class="javax.swing.JLabel" binding="tipoPrestazione">
        <constraints>
